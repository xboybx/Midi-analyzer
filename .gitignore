# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ─── Electron ───────────────────────────────
# electron-builder output directories
/dist/
/release/
/dist-electron/

# Electron packaged app caches
/electron/out/
*.app
*.exe
*.dmg
*.AppImage
*.deb
*.snap
*.rpm
*.zip
*.tar.gz

# electron-builder lock
electron-builder.lock

# ─── App-specific ───────────────────────────
# Audio sample cache (downloaded at runtime)
/public/samples/

# OS artefacts
Thumbs.db
Desktop.ini
ehthumbs.db

# Editor / IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
